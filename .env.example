# ─── Variables obligatoires ───────────────────────────────────────────────────
# Le serveur refuse de démarrer si l'une de ces variables est absente.

# Client ID de l'application OAuth créée dans Tempo → Settings → API Integration
TEMPO_CLIENT_ID=

# Client Secret de l'application OAuth Tempo (ne pas exposer publiquement)
TEMPO_CLIENT_SECRET=

# URI de callback enregistrée dans Tempo — doit correspondre EXACTEMENT
# Railway  : https://votre-app.up.railway.app/oauth/callback
# Local    : http://localhost:3000/oauth/callback
OAUTH_REDIRECT_URI=

# URL publique du serveur — utilisée dans les réponses OAuth discovery
# Doit commencer par https:// (ou http:// en développement local uniquement)
# Railway  : https://votre-app.up.railway.app
# Local    : http://localhost:3000
PUBLIC_URL=

# URL de votre instance Jira Cloud
JIRA_URL=https://votre-org.atlassian.net

# ─── Variables optionnelles ───────────────────────────────────────────────────

# Port d'écoute du serveur (défaut : 3000)
# Railway injecte PORT automatiquement — ne pas définir manuellement sur Railway
# PORT=3000

# URL du token endpoint Tempo (ne modifier que si Tempo change son endpoint)
# TEMPO_TOKEN_URL=https://api.tempo.io/oauth/token
